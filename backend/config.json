        "Observability & Pipeline Reliability"
      ]
    },
    "Generative AI & AI Stack": {
      "subcategories": [
        "Generative AI (General Concepts)",
        "RAG – All Patterns",
        "LangChain",
        "Agentic AI Systems",
        "Vector Stores & Embeddings",
        "LLMs: Gemini, Claude",
