    },
    "engineer": {
      "label": "Lead Data Engineer",
      "description": "Scalability, performance optimization, production-grade data pipelines"
    },
    "ai_engineer": {
      "label": "Lead AI Engineer",
      "description": "Productionizing AI systems, GenAI infrastructure, MLOps"
    },
    "cto": {
      "label": "Chief Data Architect / CTO",
      "description": "All-in-one enterprise data & GenAI platform leadership"
    }
  },
  "categories": {
    "Cloud Platforms": {
      "subcategories": [
        "Azure (General)",
        "Multi-Cloud Strategy",
        "Hybrid Architecture",
        "Azure Networking & Security"
      ]
    },
    "Core Data Platform": {
      "subcategories": [
        "Azure Data Factory (ADF)",
        "Azure Data Lake Storage Gen2 (ADLS)",
        "Azure Synapse Analytics",
        "Azure Event Hub",
        "Azure SQL Database",
        "Azure Key Vault",
        "Azure Databricks",
        "Snowflake",
        "Delta Lake",
        "Unity Catalog"
      ]
    },
    "Data Architecture": {
      "subcategories": [
        "Medallion Architecture (Bronze/Silver/Gold)",
        "Lakehouse vs Data Warehouse",
        "Data Vault 2.0",
        "Star Schema & Dimensional Modelling",
