{
  "llm_providers": {
    "claude": {
      "model": "claude-sonnet-4-20250514",
      "api_key_env": "ANTHROPIC_API_KEY",
      "max_tokens": 4000
    },
    "gemini": {
      "model": "gemini-1.5-pro",
      "api_key_env": "GEMINI_API_KEY",
      "max_tokens": 4000
    }
  },
  "difficulty_levels": ["Easy", "Medium", "Hard"],
